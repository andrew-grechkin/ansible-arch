[Trigger]
Type = Path
Operation = Install
Operation = Upgrade
Target = usr/lib/initcpio/*

[Trigger]
Type = Path
Operation = Install
Operation = Upgrade
Target = boot/*

[Trigger]
Type = Package
Operation = Install
Operation = Upgrade
Target = linux*

[Action]
Depends = rsync
Description = Propagating /boot changes to /efi...
When = PostTransaction
Exec = /usr/bin/bash -c 'test -d /efi && /usr/bin/rsync -tv /boot/* /efi/ 1>/dev/null'
